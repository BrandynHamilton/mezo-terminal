# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Admin address (can update Mezo contract defaults)
ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# Bank account address (automatically injected into vaults)
BANK_ACCOUNT=0x0000000000000000000000000000000000000000

# Private key for broadcasting transactions (DO NOT COMMIT)
PRIVATE_KEY=

# =============================================================================
# MEZO MAINNET ADDRESSES
# =============================================================================
# BTC is the native token on Mezo (18 decimals)
# All addresses from MUSD official documentation
# Source: https://mezo.org/docs/developers/musd/musd-redemptions/
# Explorer: https://explorer.mezo.org

BORROWER_OPERATIONS=0x44b1bac67dDA612a41a58AAf779143B181dEe031
TROVE_MANAGER=0x94AfB503dBca74aC3E4929BACEeDfCe19B93c193
SORTED_TROVES=0x8C5DB4C62BF29c1C4564390d10c20a47E0b2749f
HINT_HELPERS=0xD267b3bE2514375A075fd03C3D9CBa6b95317DC3
MUSD_TOKEN=0xdD468A1DDc392dcdbEf6db6e34E89AA338F9F186

# =============================================================================
# MEZO TESTNET ADDRESSES
# =============================================================================
